# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# MongoDB connection string from MongoDB Atlas (free tier is fine).
# Atlas: create a cluster, then Database > Connect > Drivers, and copy the URI.
# Remember to add your IP (or 0.0.0.0/0 for Vercel) to Network Access.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Database name (optional, defaults to "elroykimbi").
MONGODB_DB="elroykimbi"

# Password for the private /admin page (moderate comments, read submissions).
# Pick something long and random.
ADMIN_PASSWORD="change-me-to-something-long-and-random"
